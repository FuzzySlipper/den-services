# Artifacts service secrets.
# Values belong in /etc/den-services/artifacts.env on den-srv.

ARTIFACTS_CONFIG_PATH=/data/services/artifacts/config/config.yaml
DEN_ARTIFACTS_BASE_URL=http://127.0.0.1:8090
DEN_ARTIFACTS_DATABASE_URL=postgres://den_artifacts_app:replace-with-password@127.0.0.1:5433/denservices
DEN_ARTIFACTS_SERVICE_TOKEN=replace-with-service-token
