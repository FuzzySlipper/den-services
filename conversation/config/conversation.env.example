# Conversation secrets and env-only settings.
# Copy to /etc/den-services/conversation.env on den-srv and set real values.

CONVERSATION_CONFIG_PATH=/data/services/conversation/config/config.yaml
DEN_CHANNELS_DATABASE_URL=postgres://den_channels_app:replace-with-password@127.0.0.1:5433/denservices
DEN_CONVERSATION_SERVICE_TOKEN=replace-with-service-token
