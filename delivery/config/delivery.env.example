# Delivery secrets and env-only settings.
# Copy to /etc/den-services/delivery.env on den-srv and set real values.

DELIVERY_CONFIG_PATH=/data/services/delivery/config/config.yaml
DEN_DELIVERY_DATABASE_URL=postgres://den_delivery_app:replace-with-password@127.0.0.1:5433/denservices
DEN_DELIVERY_SERVICE_TOKEN=replace-with-service-token
DEN_DELIVERY_RUNTIME_SERVICE_TOKEN=replace-with-runtime-service-token
