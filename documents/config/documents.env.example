DEN_DOCUMENTS_CONFIG_PATH=/etc/den/documents/config.yaml
DEN_DOCUMENTS_DATABASE_URL=postgres://den_documents_app:change-me@127.0.0.1:5432/den?sslmode=disable
DEN_DOCUMENTS_SERVICE_TOKEN=change-me
DEN_DOCUMENTS_APP_PASSWORD=change-me

DEN_PROJECTS_BASE_URL=http://127.0.0.1:8091
DEN_PROJECTS_SERVICE_TOKEN=change-me

# Optional until agent-guidance has a successor read endpoint. If unset,
# archive preflight reports document-local references only and marks guidance
# references as unavailable in the response.
DEN_AGENT_GUIDANCE_BASE_URL=
DEN_AGENT_GUIDANCE_SERVICE_TOKEN=
