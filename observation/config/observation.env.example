# Observation secrets and env-only settings.
# Copy to /etc/den-services/observation.env on den-srv and set real values.

OBSERVATION_CONFIG_PATH=/data/services/observation/config/config.yaml
DEN_OBSERVATION_DATABASE_URL=postgres://den_observation_app:replace-with-password@127.0.0.1:5433/denservices
DEN_OBSERVATION_SERVICE_TOKEN=replace-with-service-token
