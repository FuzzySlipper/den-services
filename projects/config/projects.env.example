# Projects service secrets.
# Values belong in /etc/den-services/projects.env on den-srv.

PROJECTS_CONFIG_PATH=/data/services/projects/config/config.yaml
DEN_PROJECTS_BASE_URL=http://127.0.0.1:8091
DEN_PROJECTS_DATABASE_URL=postgres://den_projects_app:replace-with-password@127.0.0.1:5433/denservices
DEN_PROJECTS_SERVICE_TOKEN=replace-with-service-token
