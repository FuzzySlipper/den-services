# Runtime secrets and env-only settings.
# Copy to /etc/den-services/runtime.env on den-srv and set real values.

RUNTIME_CONFIG_PATH=/data/services/runtime/config/config.yaml
DEN_RUNTIME_DATABASE_URL=postgres://den_runtime_app:replace-with-password@127.0.0.1:5433/denservices
DEN_RUNTIME_SERVICE_TOKEN=replace-with-service-token
