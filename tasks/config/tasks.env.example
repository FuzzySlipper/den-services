# Tasks service secrets.
# Values belong in /etc/den-services/tasks.env on den-srv.

TASKS_CONFIG_PATH=/data/services/tasks/config/config.yaml
DEN_TASKS_BASE_URL=http://127.0.0.1:8092
DEN_TASKS_DATABASE_URL=postgres://den_tasks_app:replace-with-password@127.0.0.1:5433/denservices
DEN_TASKS_SERVICE_TOKEN=replace-with-service-token
DEN_PROJECTS_BASE_URL=http://127.0.0.1:8091
DEN_PROJECTS_SERVICE_TOKEN=replace-with-projects-service-token
