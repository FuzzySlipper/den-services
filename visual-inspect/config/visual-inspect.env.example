# Visual Inspect service secrets and env-only settings.
# Values belong in /etc/den-services/visual-inspect.env on den-srv.

VISUAL_INSPECT_CONFIG_PATH=/data/services/visual-inspect/config/config.yaml
DEN_VISUAL_INSPECT_TOKEN=<service-token>
DEN_VISUAL_INSPECT_LLM_BASE_URL=http://192.168.1.23:13305/v1
# The initial local model endpoint does not require an API key; leave blank unless the provider changes.
DEN_VISUAL_INSPECT_LLM_API_KEY=
